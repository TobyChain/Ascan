# Ascan 环境变量配置
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# 所有配置项均对应 src/config/settings.py 中的 pydantic Field
#
# 注意：pydantic-settings 不支持行内注释，值后面不能写 # 注释

# ========== LLM 配置（必填）==========
# OpenAI 兼容 API（如 OpenAI、Anthropic / Claude via proxy、阿里通义、Together、SiliconFlow、本地 vLLM 等）
IDEALAB_API_KEY=""
IDEALAB_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o-mini"
# 单次请求超时（秒），默认 120
# LLM_TIMEOUT=120
# 最大重试次数，默认 3
# LLM_MAX_RETRIES=3

# ========== GitHub Agent 配置 ==========
# GitHub Personal Access Token（需要 public_repo read scope）
GITHUB_TOKEN=""
# 追踪的 GitHub topic 列表（逗号分隔）
# GITHUB_TOPICS="digital-twin,digital-avatar,recommendation-system,product-recommendation,e-commerce,product-inspection,compliance-detection,content-moderation,customer-service,chatbot,conversational-ai,llm-agent,ai-agent,rag,multi-agent"
# 每个 topic 最多抓取仓库数，默认 8
# GITHUB_MAX_REPOS_PER_TOPIC=8
# 最低 star 数过滤，默认 500
# GITHUB_MIN_STARS=500
# 送入 LLM 深度分析的 Top N 仓库，默认 20
# GITHUB_TOP_ANALYZE=20

# ========== ArXiv 配置 ==========
# 要抓取的 arXiv 分类（JSON 数组或逗号分隔）
ARXIV_SUBJECTS=["cs.AI","cs.IR","cs.CL","cs.MA","cs.CV"]
# 日期偏移天数（默认 1 = 昨天）
# ARXIV_DATE_OFFSET_DAYS=1
# 每个分类最大论文数，默认 200
# MAX_PAPERS_PER_SUBJECT=200
# 总最大论文数，默认 500
# MAX_TOTAL_PAPERS=500

# ========== 飞书推送（可选）==========
# 配置后会通过飞书 OpenAPI 上传报告 + 推送卡片通知
# ENABLE_FEISHU_PUSH=false
# FEISHU_APP_ID=""
# FEISHU_APP_SECRET=""
# FEISHU_DOCX_FOLDER_TOKEN=""
# FEISHU_DOCX_BASE_URL="https://feishu.cn/docx"
# FEISHU_WEBHOOK_URL=""

# ========== Jina Reader（可选）==========
# 用于抓取 arXiv 列表页 / 网页快读；不填 key 走匿名访问
# JINA_API_KEY=""
# JINA_BASE_URL="https://r.jina.ai"

# ========== 应用配置 ==========
# HTML 日报输出目录，默认 ./docs
# OUTPUT_DIR=./docs
# 数据库连接，默认 SQLite
# DATABASE_URL=sqlite:///./database/arxiv_papers.db
# 日志级别：DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
